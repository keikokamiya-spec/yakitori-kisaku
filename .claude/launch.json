{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static File Server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),fs=require('fs'),p=require('path'),R='/tmp/yakitori-kisaku',M={'.html':'text/html;charset=utf-8','.css':'text/css','.js':'application/javascript','.png':'image/png','.jpg':'image/jpeg','.jpeg':'image/jpeg','.gif':'image/gif','.svg':'image/svg+xml'};h.createServer((q,r)=>{let u=decodeURIComponent(q.url.split('?')[0]);if(u==='/')u='/index.html';const f=p.join(R,u);if(!f.startsWith(R)){r.writeHead(403);r.end();return;}fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not Found');return;}r.writeHead(200,{'Content-Type':M[p.extname(f).toLowerCase()]||'application/octet-stream'});r.end(d);});}).listen(8080,()=>console.log('Serving on http://localhost:8080'));"],
      "port": 8080
    }
  ]
}
